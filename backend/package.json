  },
  "devDependencies": {
    "jest": "^30.3.0",
    "prisma": "^6.19.3",
    "supertest": "^7.2.2"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.js"],
    "coverageThreshold": {
      "global": {
        "lines": 70,
